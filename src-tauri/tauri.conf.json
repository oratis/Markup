{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markup",
  "version": "0.0.1",
  "identifier": "com.appkon.markup",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Markup",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: tauri:; font-src 'self' data:; connect-src 'self' tauri: ipc: ws://localhost:1421"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "public.app-category.productivity",
    "shortDescription": "High-performance Markdown editor",
    "longDescription": "Markup is a Typora-style WYSIWYG Markdown editor for macOS, built with Tauri and Milkdown.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "exceptionDomain": ""
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx", "mkd"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Default"
      }
    ]
  },
  "plugins": {}
}
