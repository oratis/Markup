{
  "name": "markup",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "description": "High-performance Markdown editor for macOS — Typora-spirit clone",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --target x86_64-apple-darwin",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:rust": "cd src-tauri && cargo test",
    "test:e2e": "playwright test",
    "bench:spike03": "cd src-tauri && cargo test --release --test spike_03 -- --nocapture --ignored",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.4",
    "@codemirror/search": "^6.5.7",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.43.0",
    "@milkdown/core": "^7.21.2",
    "@milkdown/ctx": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/plugin-clipboard": "^7.21.2",
    "@milkdown/plugin-cursor": "^7.21.2",
    "@milkdown/plugin-diagram": "^7.5.0",
    "@milkdown/plugin-history": "^7.21.2",
    "@milkdown/plugin-indent": "^7.21.2",
    "@milkdown/plugin-listener": "^7.21.2",
    "@milkdown/plugin-math": "^7.5.0",
    "@milkdown/preset-commonmark": "^7.21.2",
    "@milkdown/preset-gfm": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@milkdown/transformer": "^7.21.2",
    "@milkdown/utils": "^7.21.2",
    "@prosemirror-adapter/react": "^0.5.3",
    "@tanstack/react-virtual": "^3.10.9",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "katex": "^0.16.11",
    "marked": "^16.4.2",
    "mermaid": "^11.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "@tailwindcss/postcss": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
